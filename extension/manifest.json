{
  "manifest_version": 3,
  "name": "Open URL In Browser",
  "version": "1.0.0",
  "description": "Open the current tab, selected tabs, or all tabs in a different browser.",

  "key": "",

  "permissions": [
    "tabs",
    "storage",
    "nativeMessaging",
    "contextMenus"
  ],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
